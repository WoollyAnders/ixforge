# Rust
/target
**/target
Cargo.lock.bak

# Node / front end
node_modules
dist
dist-ssr
.vite
*.local

# Tauri build output + generated schemas
app/src-tauri/target
app/src-tauri/gen

# Editor / OS
.DS_Store
.idea
.vscode/*
!.vscode/extensions.json
*.log

# USB captures are large and provenance-sensitive. Track deliberately (git-lfs)
# rather than by accident. Protocol *notes* (docs/protocols/*.md) ARE committed.
/captures/*.pcap
/captures/*.pcapng

# Device reference images are tracing inputs only — keep them LOCAL, never commit
# third-party product photos (copyrighted). Put references here; commit the
# derived data (profiles + deviceArt chassis specs), not the images.
/assets/refs/
